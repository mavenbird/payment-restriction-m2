<sections xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="urn:magento:mftf:Page/etc/SectionObject.xsd">

    <section name="AdminConfigurationsPayrestrictionSection">
        <element name="IncludeTaxInSubtotal" type="select" selector="//select[@id='payrestriction_general_tax']"/>
        <element name="UseSubtotalAfterDiscount" type="select" selector="//select[@id='payrestriction_general_discount']"/>
        <element name="GeneralTab" type="button" selector="//a[@id='payrestriction_general-head']"/>
        <element name="GeneralTabOpen" type="block" selector="//a[@id='payrestriction_general-head'][@class='open']"/>
        <element name="Save" type="button" selector="//button[@id='save']"/>
    </section>

</sections>